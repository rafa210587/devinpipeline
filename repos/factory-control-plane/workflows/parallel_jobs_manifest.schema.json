{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ParallelJobsManifest",
  "type": "object",
  "required": ["max_concurrency", "jobs"],
  "properties": {
    "max_concurrency": {"type": "integer", "minimum": 1},
    "jobs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "pipeline", "input_artifact"],
        "properties": {
          "name": {"type": "string"},
          "pipeline": {"type": "string", "enum": ["full", "resume", "intake", "brief", "tech", "build", "validate", "docs", "learn"]},
          "input_artifact": {"type": "string"},
          "output_dir": {"type": ["string", "null"]},
          "resume_from": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
