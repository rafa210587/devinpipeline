# Devin credentials and org
DEVIN_API_KEY=
DEVIN_ORG_ID=
DEVIN_MCP_BASE_URL=
DEVIN_MCP_TOOL_CALL_ENDPOINT=/tools/call
DEVIN_MCP_AUTH_TOKEN=

# Playbook IDs used by factory_config.json placeholders
PLAYBOOK_INTAKE_ORCHESTRATOR=
PLAYBOOK_BRIEF_ORCHESTRATOR=
PLAYBOOK_TECH_ORCHESTRATOR=
PLAYBOOK_BUILD_ORCHESTRATOR=
PLAYBOOK_VALIDATION_ORCHESTRATOR=
PLAYBOOK_DOCS_ORCHESTRATOR=
PLAYBOOK_LEARNING_ORCHESTRATOR=

# Architecture Reference
ARR_URL=https://github.com/your-org/architecture-reference.git

# Corporate storage repo (local clone path of the GitHub repo used by Devin)
FACTORY_GITHUB_REPO_PATH=

# Optional override for config path
# DEVIN_FACTORY_CONFIG_PATH=C:\\path\\to\\factory_config.json
