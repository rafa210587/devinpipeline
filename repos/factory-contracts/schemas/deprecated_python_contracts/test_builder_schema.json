{
  "type": "object",
  "required": [
    "approved_to_merge",
    "module_file",
    "test_files",
    "coverage_targets"
  ],
  "properties": {
    "approved_to_merge": {"type": "boolean"},
    "module_file": {"type": "string"},
    "test_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "content", "test_type"],
        "properties": {
          "path": {"type": "string"},
          "content": {"type": "string"},
          "test_type": {
            "type": "string",
            "enum": ["unit", "integration"]
          }
        }
      }
    },
    "coverage_targets": {
      "type": "object",
      "properties": {
        "stories_targeted": {"type": "array", "items": {"type": "string"}},
        "contracts_targeted": {"type": "array", "items": {"type": "string"}}
      }
    },
    "notes": {"type": "string"}
  }
}
