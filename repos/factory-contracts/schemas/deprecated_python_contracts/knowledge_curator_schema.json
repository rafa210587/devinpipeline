{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["knowledge_notes", "publication_plan"],
  "properties": {
    "knowledge_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "trigger_description", "body"],
        "properties": {
          "name": {"type": "string"},
          "trigger_description": {"type": "string"},
          "body": {"type": "string"}
        }
      }
    },
    "dedup_decisions": {"type": "array"},
    "publication_plan": {"type": "object"}
  }
}
