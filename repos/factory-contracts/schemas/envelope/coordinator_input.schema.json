{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CoordinatorInput",
  "type": "object",
  "required": ["run_id", "stage", "objective", "params_profile", "repos", "skill_registry_file"],
  "properties": {
    "run_id": {"type": "string", "minLength": 1},
    "stage": {"type": "string", "enum": ["p0", "p1", "p2", "p3", "p4", "p5", "p6"]},
    "objective": {"type": "string", "minLength": 1},
    "params_profile": {"type": "string"},
    "resume_from": {"type": ["string", "null"]},
    "skill_registry_file": {"type": "string"},
    "devin_skill_registry_root": {"type": ["string", "null"]},
    "memory_root": {"type": ["string", "null"]},
    "knowledge_root": {"type": ["string", "null"]},
    "architecture_reference_root": {"type": ["string", "null"]},
    "architecture_reference_fallback_root": {"type": ["string", "null"]},
    "input_artifacts": {
      "type": "object",
      "additionalProperties": true
    },
    "repos": {
      "type": "object",
      "required": [
        "control_plane",
        "contracts",
        "params",
        "architecture_reference",
        "refinement_support",
        "memory_knowledge",
        "runtime_data",
        "target_repos"
      ],
      "properties": {
        "control_plane": {"type": "string"},
        "contracts": {"type": "string"},
        "params": {"type": "string"},
        "architecture_reference": {"type": "string"},
        "refinement_support": {"type": "string"},
        "memory_knowledge": {"type": "string"},
        "runtime_data": {"type": "string"},
        "target_repos": {"type": "string"}
      }
    },
    "repo_fallbacks_file": {"type": ["string", "null"]},
    "repo_fallbacks": {
      "type": "object",
      "properties": {
        "control_plane": {"type": "object", "additionalProperties": true},
        "contracts": {"type": "object", "additionalProperties": true},
        "params": {"type": "object", "additionalProperties": true},
        "architecture_reference": {"type": "object", "additionalProperties": true},
        "refinement_support": {"type": "object", "additionalProperties": true},
        "memory_knowledge": {"type": "object", "additionalProperties": true},
        "runtime_data": {"type": "object", "additionalProperties": true},
        "target_repos": {"type": "object", "additionalProperties": true}
      },
      "additionalProperties": false
    },
    "toggles": {
      "type": "object",
      "additionalProperties": true
    },
    "handoff_context": {
      "type": "object",
      "additionalProperties": true
    },
    "communication_contracts": {
      "type": "object",
      "properties": {
        "coordinator_output_schema": {"type": ["string", "null"]},
        "subagent_task_schema": {"type": ["string", "null"]},
        "subagent_result_schema": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    },
    "persistence_targets": {
      "type": "object",
      "additionalProperties": true
    },
    "stage_review_policy": {
      "type": "object",
      "properties": {
        "require_human_approval": {"type": "boolean"},
        "require_stage_closure_summary": {"type": "boolean"},
        "require_stage_review_packet": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "debate_policy": {
      "type": "object",
      "properties": {
        "internal_first": {"type": "boolean"},
        "quorum_min_agents": {"type": ["integer", "null"], "minimum": 2},
        "quorum_required_for_material_conflict": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "artifact_index_root": {"type": ["string", "null"]}
  },
  "additionalProperties": false
}
