{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QuorumIssue",
  "type": "object",
  "required": ["run_id", "stage", "issue_id", "question", "options", "participants", "decision"],
  "properties": {
    "run_id": {"type": "string"},
    "stage": {"type": "string"},
    "issue_id": {"type": "string"},
    "question": {"type": "string"},
    "options": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string"}
    },
    "participants": {
      "type": "array",
      "minItems": 2,
      "items": {"type": "string"}
    },
    "decision": {
      "type": "object",
      "required": ["selected_option", "rationale", "confidence"],
      "properties": {
        "selected_option": {"type": "string"},
        "rationale": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
