{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubagentResult",
  "type": "object",
  "required": ["run_id", "stage", "task_id", "status", "confidence"],
  "properties": {
    "run_id": {"type": "string"},
    "stage": {"type": "string"},
    "task_id": {"type": "string"},
    "status": {"type": "string", "enum": ["done", "blocked", "failed"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "summary": {"type": "string"},
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "description"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "description": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
