{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubagentResult",
  "type": "object",
  "required": ["status"],
  "properties": {
    "run_id": {"type": "string"},
    "stage": {"type": "string"},
    "task_id": {"type": "string"},
    "agent_type": {"type": "string"},
    "status": {"type": "string", "enum": ["done", "blocked", "failed"]},
    "confidence": {
      "oneOf": [
        {"type": "number", "minimum": 0, "maximum": 1},
        {"type": "string"}
      ]
    },
    "artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "artifact_index": {
      "type": "object",
      "additionalProperties": true
    },
    "summary": {"type": "string"},
    "writes_performed": {
      "type": "array",
      "items": {"type": "string"}
    },
    "context_updates": {
      "type": "array",
      "items": {"type": "string"}
    },
    "integration_impacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "read_repos_used": {
      "type": "array",
      "items": {"type": "string"}
    },
    "self_check": {
      "type": "object",
      "additionalProperties": true
    },
    "debate_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question", "position"],
        "properties": {
          "question": {"type": "string"},
          "position": {"type": "string"},
          "evidence": {"type": ["string", "null"]}
        },
        "additionalProperties": false
      }
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "description"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string"},
          "description": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "followup_recommendation": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
