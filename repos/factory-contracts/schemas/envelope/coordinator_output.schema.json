{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CoordinatorOutput",
  "type": "object",
  "required": ["run_id", "stage", "status", "outputs", "confidence"],
  "properties": {
    "run_id": {"type": "string"},
    "stage": {"type": "string", "enum": ["p0", "p1", "p2", "p3", "p4", "p5", "p6"]},
    "status": {"type": "string", "enum": ["completed", "failed", "skipped", "blocked"]},
    "outputs": {"type": "object", "additionalProperties": true},
    "next_stage": {"type": ["string", "null"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "reason", "severity"],
        "properties": {
          "id": {"type": "string"},
          "reason": {"type": "string"},
          "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]}
        },
        "additionalProperties": false
      }
    },
    "escalations": {
      "type": "array",
      "items": {"type": "object", "additionalProperties": true}
    }
  },
  "additionalProperties": false
}
