{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubagentTask",
  "type": "object",
  "required": ["run_id", "stage", "task_id", "role", "objective", "input", "dependencies", "priority"],
  "properties": {
    "run_id": {"type": "string"},
    "stage": {"type": "string"},
    "task_id": {"type": "string"},
    "role": {"type": "string"},
    "objective": {"type": "string"},
    "input": {"type": "object", "additionalProperties": true},
    "input_artifact_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "skill_registry_ref": {"type": ["string", "null"]},
    "selected_skill_refs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "skill_selection_notes": {"type": ["string", "null"]},
    "memory_refs": {
      "type": "array",
      "description": "Specific memory files, records, or summaries the subagent should consider. Empty means no memory is required for the task.",
      "items": {"type": "string"}
    },
    "knowledge_refs": {
      "type": "array",
      "description": "Specific knowledge files, candidates, or institutional rules the subagent should consider. Empty means no knowledge is required for the task.",
      "items": {"type": "string"}
    },
    "architecture_reference_refs": {
      "type": "array",
      "description": "Specific architecture-reference docs, guardrails, patterns, or domain profiles relevant to the task.",
      "items": {"type": "string"}
    },
    "context_packet": {
      "type": "object",
      "description": "Compact context needed to execute a small task without losing cross-task continuity.",
      "properties": {
        "task_slice_size_rule": {"type": "string"},
        "target_repo_alias": {"type": ["string", "null"]},
        "target_workspace_root": {"type": ["string", "null"]},
        "target_files": {
          "type": "array",
          "items": {"type": "string"}
        },
        "current_repo_state_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "upstream_task_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "upstream_outputs_summary": {
          "type": "array",
          "items": {"type": "string"}
        },
        "related_task_refs": {
          "type": "array",
          "items": {"type": "string"}
        },
        "known_integration_impacts": {
          "type": "array",
          "items": {"type": "string"}
        },
        "workspace_diff_summary_ref": {"type": ["string", "null"]},
        "context_ledger_ref": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string"}
    },
    "priority": {"type": "integer", "minimum": 1, "maximum": 5},
    "deadline_seconds": {"type": ["integer", "null"], "minimum": 1},
    "task_slice_size": {
      "type": "string",
      "enum": ["tiny", "small", "medium"]
    },
    "context_budget_hint": {
      "type": "string",
      "enum": ["tiny", "small", "medium"]
    },
    "expected_output_artifacts": {
      "type": "array",
      "items": {"type": "string"}
    },
    "output_schema_ref": {"type": ["string", "null"]},
    "must_read_repos": {
      "type": "array",
      "items": {"type": "string"}
    },
    "must_write_repos": {
      "type": "array",
      "items": {"type": "string"}
    },
    "persistence_targets": {
      "type": "object",
      "additionalProperties": true
    },
    "acceptance_checks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "debate_context": {
      "type": "object",
      "properties": {
        "debate_id": {"type": ["string", "null"]},
        "position_to_argue": {"type": ["string", "null"]},
        "questions_to_answer": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
