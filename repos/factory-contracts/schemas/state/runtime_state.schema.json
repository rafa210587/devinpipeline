{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RuntimeState",
  "type": "object",
  "required": ["run_id", "current_stage", "stage_status", "task_graph", "updated_at_utc"],
  "properties": {
    "run_id": {"type": "string"},
    "current_stage": {"type": "string"},
    "updated_at_utc": {"type": "string"},
    "stage_status": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["pending", "running", "completed", "failed", "skipped", "blocked"]
      }
    },
    "task_graph": {
      "type": "object",
      "required": ["nodes", "edges", "ready_queue", "in_progress", "done"],
      "properties": {
        "nodes": {"type": "array", "items": {"type": "string"}},
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to"],
            "properties": {
              "from": {"type": "string"},
              "to": {"type": "string"}
            },
            "additionalProperties": false
          }
        },
        "ready_queue": {"type": "array", "items": {"type": "string"}},
        "in_progress": {"type": "array", "items": {"type": "string"}},
        "done": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
