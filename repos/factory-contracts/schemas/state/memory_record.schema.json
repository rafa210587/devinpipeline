{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MemoryRecord",
  "type": "object",
  "required": ["ts_utc", "pipeline"],
  "properties": {
    "ts_utc": {"type": "string"},
    "pipeline": {"type": "string"},
    "session_id": {"type": ["string", "null"]},
    "status": {"type": ["string", "null"]},
    "release_decision": {"type": ["string", "null"]},
    "ready_for_factory": {"type": ["boolean", "null"]},
    "failed_files_count": {"type": "integer"},
    "dilemmas_count": {"type": "integer"}
  },
  "additionalProperties": true
}
