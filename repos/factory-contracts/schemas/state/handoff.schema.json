{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WorkspaceHandoff",
  "type": "object",
  "required": ["updated_at_utc", "last_pipeline", "last_status", "artifacts"],
  "properties": {
    "updated_at_utc": {"type": "string"},
    "last_pipeline": {"type": "string"},
    "last_status": {"type": ["string", "null"]},
    "repo_manifest": {
      "type": "array",
      "items": {"type": "object", "additionalProperties": true}
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    }
  },
  "additionalProperties": false
}
