    "stage_completion_rate": {"type": ["number", "null"]},
    "release_decision": {"type": ["string", "null"]},
    "quality_scores": {"type": "object", "additionalProperties": true},
    "classification_metrics": {"type": "object", "additionalProperties": true}
  },
  "additionalProperties": true
}
