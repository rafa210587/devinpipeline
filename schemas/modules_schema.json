            "enum": [
              "strategy",
              "execution",
              "risk",
              "io",
              "scheduling",
              "utilities",
              "api",
              "domain",
              "model",
              "infrastructure"
            ]
          },
          "classes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "description"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          },
          "standalone_functions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "name",
                "description"
              ],
              "properties": {
                "name": {
                  "type": "string"
                },
                "description": {
                  "type": "string"
                }
              }
            }
          },
          "depends_on": {
