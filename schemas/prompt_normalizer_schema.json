{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["normalized_prompt", "route_mode", "project_context", "intake_contract"],
  "properties": {
    "normalized_prompt": {"type": "string"},
    "route_mode": {"type": "string", "enum": ["seed_to_brief", "pre_briefed"]},
    "normalized_briefing": {"type": "object"},
    "project_context": {"type": "object"},
    "intake_contract": {"type": "object"},
    "quorum_suggested": {"type": "boolean"},
    "quorum_question": {"type": "string"}
  }
}
