{
  "type": "object",
  "required": [
    "approved",
    "findings"
  ],
  "properties": {
    "approved": {
      "type": "boolean"
    },
    "files_analyzed": {
      "type": "integer"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "severity",
          "category",
          "file",
          "location",
          "description",
          "fix"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "category": {
            "type": "string"
          },
          "file": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "fix": {
            "type": "string"
          },
          "guardrail_reference": {
            "type": "string"
          },
          "estimated_impact": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    }
  }
}