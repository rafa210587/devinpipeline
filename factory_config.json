{
  "devin": {
    "api_base": "https://api.devin.ai",
    "org_id": "${DEVIN_ORG_ID}",
    "api_key": "${DEVIN_API_KEY}",
    "endpoints": {
      "create_session": "/v3/organizations/{org_id}/sessions",
      "get_session": "/v3/organizations/{org_id}/sessions/{session_id}",
      "send_message_candidates": [
        "/v3/organizations/{org_id}/sessions/{session_id}/messages",
        "/v3beta1/organizations/{org_id}/sessions/{session_id}/messages"
      ],
      "terminate_session": "/v3/organizations/{org_id}/sessions/{session_id}"
    },
    "terminate_http_method": "DELETE",
    "terminate_archive": false,
    "terminal_statuses": [
      "exit",
      "error",
      "suspended"
    ]
  },
  "playbooks": {
    "intake": "${PLAYBOOK_INTAKE_ORCHESTRATOR}",
    "brief": "${PLAYBOOK_BRIEF_ORCHESTRATOR}",
    "tech": "${PLAYBOOK_TECH_ORCHESTRATOR}",
    "build": "${PLAYBOOK_BUILD_ORCHESTRATOR}",
    "validate": "${PLAYBOOK_VALIDATION_ORCHESTRATOR}",
    "docs": "${PLAYBOOK_DOCS_ORCHESTRATOR}",
    "learning": "${PLAYBOOK_LEARNING_ORCHESTRATOR}"
  },
  "arr": {
    "url": "${ARR_URL}",
    "branch": "main"
  },
  "runtime": {
    "poll_interval_seconds": 15,
    "gate_wait_seconds": 1800,
    "waiting_status_details": [
      "waiting_for_user",
      "waiting_for_approval"
    ],
    "waiting_detail_timeout_seconds": 1800,
    "session_defaults": {
      "repos": [],
      "knowledge_ids": [],
      "secret_ids": [],
      "bypass_approval": false,
      "use_repo_manifest_as_repos": false
    },
    "max_wait_seconds": {
      "intake": 1800,
      "brief": 7200,
      "tech": 5400,
      "build": 14400,
      "validate": 7200,
      "docs": 3600,
      "learning": 3600
    },
    "pipeline": {
      "stage_order": [
        "P0",
        "P1",
        "P2",
        "P3",
        "P4",
        "P5",
        "P6"
      ],
      "p5_requires_release_approved": true,
      "p6_owner_stage": "P6",
      "p6_is_mandatory": true,
      "require_stage_review_before_transition": true
    },
    "p0": {
      "enabled": true,
      "default_route_mode": "seed_to_brief",
      "allow_pre_briefed": true
    },
    "learning": {
      "max_wait_seconds": 3600,
      "mandatory": true,
      "promotion_policy": "always_run_at_pipeline_end"
    },
    "tracking": {
      "enabled": true,
      "execution_md": "execution_tracking.md",
      "dilemmas_md": "dilemmas_and_solutions.md",
      "sessions_jsonl": "coordinator_sessions.jsonl",
      "events_jsonl": "tracking_events.jsonl"
    },
    "memory": {
      "enabled": true,
      "episodic_jsonl": "memory/episodic_memory.jsonl",
      "semantic_jsonl": "memory/semantic_memory_candidates.jsonl",
      "summary_md": "memory/MEMORY_LOG.md"
    },
    "human_gates": {
      "after_p0": true,
      "after_p1": true,
      "after_p2": true,
      "after_p3": true,
      "after_p4": true,
      "after_p5": true,
      "after_p6": true,
      "require_explicit_approval": true
    },
    "terminal_proxy": {
      "enabled": true,
      "mirror_session_messages": true,
      "allow_input_during_wait": true,
      "announce_waiting_hint": true,
      "prompt_prefix": "[TERMINAL_PROXY]",
      "max_message_chars": 16000
    },
    "transport": {
      "mode": "http",
      "mcp": {
        "base_url": "${DEVIN_MCP_BASE_URL}",
        "tool_call_endpoint": "${DEVIN_MCP_TOOL_CALL_ENDPOINT}",
        "auth_token": "${DEVIN_MCP_AUTH_TOKEN}",
        "payload_mode": "tool_gateway",
        "timeout_seconds": 60,
        "tools": {
          "create_session": "devin_session_create",
          "get_session": "devin_session_get",
          "send_message": "devin_session_interact",
          "terminate_session": "devin_session_terminate"
        }
      }
    },
    "eval_metrics": {
      "enabled": true,
      "report_mode": "deterministic",
      "json_file": "eval_metrics.json",
      "markdown_file": "eval_metrics_report.md",
      "history_jsonl": "eval_metrics_history.jsonl",
      "ground_truth_file": "eval_ground_truth.json",
      "promote_to_shared": true
    }
  },
  "storage": {
    "mode": "github_repo",
    "github_repo_path": "${FACTORY_GITHUB_REPO_PATH}",
    "runs_root": "repos/factory-runtime-data/factory_runs",
    "shared_memory_root": "repos/factory-memory-knowledge/memory",
    "shared_knowledge_root": "repos/factory-memory-knowledge/knowledge",
    "shared_skills_root": "repos/factory-memory-knowledge/skills",
    "shared_metrics_root": "repos/factory-runtime-data/metrics",
    "enforce_repo_path": true
  },
  "git_sync": {
    "enabled": false,
    "auto_commit": false,
    "auto_push": false,
    "branch": "main",
    "commit_message_template": "devin-factory {pipeline} {ts_utc}"
  },
  "agent_runtime": {
    "default_max_concurrency": 2,
    "root_orchestrator": "playbooks/packages/shared/pipeline_global_orchestrator.md",
    "control_plane_prompt": "repos/factory-control-plane/prompts/master_pipeline_prompt.md",
    "entrypoint": {
      "mode": "root_orchestrator_first",
      "canonical_execution_contract": "root_orchestrator",
      "control_plane_prompt_role": "bootstrap_only",
      "user_entry_requires_master_prompt": false
    },
    "logs_dir": "repos/factory-runtime-data/factory_runs/_parallel_logs"
  },
  "references": {
    "devin_skill_registry": "[SKILL/FILE] /workspace/.agents/skills/",
    "factory_skill_registry": "[FILE] /workspace/repos/factory-memory-knowledge/skills/skill_registry.json",
    "factory_memory_root": "[FILE] /workspace/repos/factory-memory-knowledge/memory/",
    "factory_knowledge_root": "[FILE] /workspace/repos/factory-memory-knowledge/knowledge/",
    "arr_reference_index": "[SKILL/FILE] /workspace/architecture-reference/INDEX.md",
    "arr_reference_repo_fallback_root": "[FILE] /workspace/repos/architecture-reference/",
    "arr_guardrails": "[SKILL/FILE] /workspace/architecture-reference/guardrails/",
    "arr_patterns": "[SKILL/FILE] /workspace/architecture-reference/patterns/",
    "arr_domain_profiles": "[SKILL/FILE] /workspace/architecture-reference/domains/{domain_slug}.md"
  }
}
